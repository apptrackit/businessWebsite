---
import { ViewTransitions } from 'astro:transitions';
import HeroArtifact from '../components/HeroArtifact';
import config from '../config/config.json';
import '../styles/site.css';

const activeLocale = 'hu';
const localeCopy = config.locales[activeLocale];
const initialBotondLink = config.company.links.botond[activeLocale] ?? config.company.links.botond.en;
const initialBenceLink = config.company.links.bence[activeLocale] ?? config.company.links.bence.en;
const initialBotondLabel = initialBotondLink.replace('https://', '');
const initialBenceLabel = initialBenceLink.replace('https://', '');
const withBase = (path: string) => {
	const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
	return `${base}${path.replace(/^\/+/, '')}`;
};

const siteUrl = new URL(import.meta.env.SITE ?? 'https://tarckit.com');
const canonicalUrl = new URL(import.meta.env.BASE_URL || '/', siteUrl).toString();
const ogImageUrl = new URL(withBase('images/showcase/shot-1.svg'), siteUrl).toString();
const seoTitle = `${config.company.name} | ${localeCopy.headline}`;
const seoDescription = `${localeCopy.hero} ${localeCopy.sub}`;
const seoKeywordsByLocale = {
	hu: 'weboldal készítés, üzleti weboldal, prémium webdesign, webfejlesztés, seo weboldal, konverzió optimalizálás, landing page készítés, céges weboldal',
	en: 'business website design, premium web development, conversion focused website, landing page design, SEO ready website, web design agency, custom website development'
};
const seoKeywords = seoKeywordsByLocale[activeLocale] ?? seoKeywordsByLocale.en;
const localeTag = activeLocale === 'hu' ? 'hu_HU' : 'en_US';
const alternateLocaleTag = activeLocale === 'hu' ? 'en_US' : 'hu_HU';
const sameAsLinks = Array.from(new Set([
	config.company.links.botond.hu,
	config.company.links.botond.en,
	config.company.links.bence.hu,
	config.company.links.bence.en
]));

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebSite',
			'@id': `${canonicalUrl}#website`,
			url: canonicalUrl,
			name: config.company.name,
			inLanguage: activeLocale,
			description: seoDescription,
			publisher: {
				'@id': `${canonicalUrl}#organization`
			}
		},
		{
			'@type': 'Organization',
			'@id': `${canonicalUrl}#organization`,
			name: config.company.name,
			url: canonicalUrl,
			logo: new URL(withBase('favicon.svg'), siteUrl).toString(),
			sameAs: sameAsLinks
		},
		{
			'@type': 'ProfessionalService',
			'@id': `${canonicalUrl}#service`,
			name: `${config.company.name} Web Design & Development`,
			url: canonicalUrl,
			image: ogImageUrl,
			description: seoDescription,
			serviceType: [
				'Business Website Design',
				'Custom Web Development',
				'Landing Page Design',
				'Website Maintenance',
				'SEO-ready Information Architecture'
			],
			areaServed: 'Worldwide',
			provider: {
				'@id': `${canonicalUrl}#organization`
			}
		}
	]
};

const faviconHref = withBase('favicon.svg?v=2');
type LocaleCopy = typeof localeCopy;

interface ShowcaseShot {
	src: string;
	altKey: keyof LocaleCopy;
	titleKey: keyof LocaleCopy;
	descKey: keyof LocaleCopy;
}

const showcaseShots: ShowcaseShot[] = [
	{ src: withBase('images/showcase/shot-1.svg'), altKey: 'shotOneAlt', titleKey: 'shotOneTitle', descKey: 'shotOneDesc' },
	{ src: withBase('images/showcase/shot-2.svg'), altKey: 'shotTwoAlt', titleKey: 'shotTwoTitle', descKey: 'shotTwoDesc' },
	{ src: withBase('images/showcase/shot-3.svg'), altKey: 'shotThreeAlt', titleKey: 'shotThreeTitle', descKey: 'shotThreeDesc' },
	{ src: withBase('images/showcase/shot-4.svg'), altKey: 'shotFourAlt', titleKey: 'shotFourTitle', descKey: 'shotFourDesc' },
	{ src: withBase('images/showcase/shot-5.svg'), altKey: 'shotFiveAlt', titleKey: 'shotFiveTitle', descKey: 'shotFiveDesc' },
	{ src: withBase('images/showcase/shot-6.svg'), altKey: 'shotSixAlt', titleKey: 'shotSixTitle', descKey: 'shotSixDesc' }
];
---

<html lang={activeLocale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<link rel="shortcut icon" type="image/svg+xml" href={faviconHref} />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={seoDescription} />
		<meta name="keywords" content={seoKeywords} />
		<meta name="author" content={config.company.name} />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="theme-color" content={config.design.primaryColor} />

		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="hu" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={canonicalUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={config.company.name} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={seoTitle} />
		<meta property="og:description" content={seoDescription} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={localeCopy.shotOneTitle} />
		<meta property="og:locale" content={localeTag} />
		<meta property="og:locale:alternate" content={alternateLocaleTag} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={seoTitle} />
		<meta name="twitter:description" content={seoDescription} />
		<meta name="twitter:image" content={ogImageUrl} />

		<meta name="generator" content={Astro.generator} />
		<ViewTransitions />
		<title>{seoTitle}</title>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
	</head>
	<body style={`--primary: ${config.design.primaryColor};`}>
		<main class="site-shell">
			<nav class="nav glass-card floating-header" id="floating-header">
				<div class="brand">
					<img class="brand-mark" src={withBase('favicon.svg')} alt="Tarckit logo" width="22" height="22" />
					<span>{config.company.name}</span>
				</div>
				<div class="nav-links nav-controls">
					<div class="custom-dropdown desktop-dropdown" data-dropdown="locale">
						<button class="dropdown-trigger" type="button" aria-expanded="false" aria-controls="locale-menu">
							<span class="dropdown-label" data-i18n="languageLabel">{localeCopy.languageLabel}</span>
							<span class="dropdown-value" id="locale-current">HU</span>
							<span class="dropdown-caret" aria-hidden="true">⌄</span>
						</button>
						<div class="dropdown-menu" id="locale-menu" role="menu">
							<button class="dropdown-item" type="button" data-locale-value="hu">HU</button>
							<button class="dropdown-item" type="button" data-locale-value="en">EN</button>
						</div>
					</div>

					<div class="custom-dropdown desktop-dropdown" data-dropdown="theme">
						<button class="dropdown-trigger" type="button" aria-expanded="false" aria-controls="theme-menu">
							<span class="dropdown-label" data-i18n="themeLabel">{localeCopy.themeLabel}</span>
							<span class="dropdown-value" id="theme-current" data-i18n="themeDark">{localeCopy.themeDark}</span>
							<span class="dropdown-caret" aria-hidden="true">⌄</span>
						</button>
						<div class="dropdown-menu" id="theme-menu" role="menu">
							<button class="dropdown-item" type="button" data-theme-value="light" data-i18n="themeLight">{localeCopy.themeLight}</button>
							<button class="dropdown-item" type="button" data-theme-value="dark" data-i18n="themeDark">{localeCopy.themeDark}</button>
						</div>
					</div>

					<div class="custom-dropdown mobile-dropdown" data-dropdown="mobile-controls">
						<button class="dropdown-trigger" type="button" aria-expanded="false" aria-controls="mobile-controls-menu">
							<span class="dropdown-value" id="mobile-controls-current">HU · {localeCopy.themeDark}</span>
							<span class="dropdown-caret" aria-hidden="true">⌄</span>
						</button>
						<div class="dropdown-menu dropdown-menu--mobile" id="mobile-controls-menu" role="menu">
							<p class="dropdown-group-title" data-i18n="languageLabel">{localeCopy.languageLabel}</p>
							<div class="dropdown-group">
								<button class="dropdown-item" type="button" data-locale-value="hu">HU</button>
								<button class="dropdown-item" type="button" data-locale-value="en">EN</button>
							</div>
							<p class="dropdown-group-title" data-i18n="themeLabel">{localeCopy.themeLabel}</p>
							<div class="dropdown-group">
								<button class="dropdown-item" type="button" data-theme-value="light" data-i18n="themeLight">{localeCopy.themeLight}</button>
								<button class="dropdown-item" type="button" data-theme-value="dark" data-i18n="themeDark">{localeCopy.themeDark}</button>
							</div>
						</div>
					</div>
				</div>
			</nav>

			<div class="snap-stage">
				<section class="hero glass-card">
					<div class="hero-copy">
						<h1 data-i18n="headline">{localeCopy.headline}</h1>
						<p id="hero-copy" data-i18n="hero">{localeCopy.hero}</p>
						<p id="sub-copy" data-i18n="sub">{localeCopy.sub}</p>
						<button id="contact-btn" type="button" data-i18n="cta">{localeCopy.cta}</button>
					</div>

					<div class="hero-visual">
						<HeroArtifact client:load accentColor={config.design.primaryColor} intensity={config.design.threeJsIntensity} />
					</div>
				</section>
			</div>

			<div class="snap-stage">
				<section class="showcase glass-card">
					<div class="showcase-head">
						<h2 data-i18n="showcaseTitle">{localeCopy.showcaseTitle}</h2>
						<p data-i18n="showcaseLead">{localeCopy.showcaseLead}</p>
					</div>
					<div class="showcase-grid">
						{showcaseShots.map((shot, index) => (
							<figure
								class={`shot shot--${index + 1}`}
								data-shot
								data-shot-src={shot.src}
								data-shot-title-key={shot.titleKey}
								role="button"
								tabindex="0"
								aria-label={localeCopy[shot.titleKey]}
							>
								<img src={shot.src} alt={localeCopy[shot.altKey]} data-i18n-alt={shot.altKey} loading="lazy" />
								<figcaption>
									<h3 data-i18n={shot.titleKey}>{localeCopy[shot.titleKey]}</h3>
									<p data-i18n={shot.descKey}>{localeCopy[shot.descKey]}</p>
								</figcaption>
							</figure>
						))}
					</div>
				</section>
			</div>

			<div class="snap-stage">
				<section class="team-links glass-card">
					<h2 data-i18n="linksTitle">{localeCopy.linksTitle}</h2>
					<p data-i18n="linksLead">{localeCopy.linksLead}</p>
					<div class="external-links">
						<a class="link-btn" id="botond-link" href={initialBotondLink} target="_blank" rel="noreferrer">{initialBotondLabel}</a>
						<a class="link-btn" id="bence-link" href={initialBenceLink} target="_blank" rel="noreferrer">{initialBenceLabel}</a>
					</div>
				</section>
			</div>

			<footer class="footer glass-card floating-footer" id="floating-footer">
				<span data-i18n="footerTagline">{localeCopy.footerTagline}</span>
			</footer>

			<div class="lightbox" id="lightbox" hidden>
				<div class="lightbox-backdrop" data-lightbox-close></div>
				<div class="lightbox-panel glass-card" role="dialog" aria-modal="true" aria-label="Image preview">
					<div class="lightbox-topbar">
						<h3 id="lightbox-title"></h3>
						<button class="lightbox-close" id="lightbox-close" type="button" data-lightbox-close data-i18n="closePreview">
							{localeCopy.closePreview}
						</button>
					</div>
					<img id="lightbox-image" src="" alt="" />
				</div>
			</div>

		</main>

		<script is:inline define:vars={{ uiConfig: JSON.stringify(config) }}>
			const parsedConfig = JSON.parse(uiConfig);
			const localeCurrent = document.querySelector('#locale-current');
			const themeCurrent = document.querySelector('#theme-current');
			const mobileControlsCurrent = document.querySelector('#mobile-controls-current');
			const ctaNode = document.querySelector('#contact-btn');
			const root = document.documentElement;
			const floatingHeader = document.querySelector('#floating-header');
			const botondLink = document.querySelector('#botond-link');
			const benceLink = document.querySelector('#bence-link');
			const lightbox = document.querySelector('#lightbox');
			const lightboxImage = document.querySelector('#lightbox-image');
			const lightboxTitle = document.querySelector('#lightbox-title');
			const floatingFooter = document.querySelector('#floating-footer');
			const footerTagline = document.querySelector('#floating-footer [data-i18n="footerTagline"]');
			const dropdowns = Array.from(document.querySelectorAll('.custom-dropdown'));
			let currentLocale = 'hu';

			const syncFooterTaglineFit = () => {
				if (!footerTagline) return;
				const currentText = (footerTagline.textContent || '').trim();
				const fullText = footerTagline.getAttribute('data-full-text') || currentText || 'Tarckit';

				footerTagline.setAttribute('data-full-text', fullText);
				footerTagline.textContent = fullText;

				requestAnimationFrame(() => {
					if (!footerTagline) return;
					const isOverflowing = footerTagline.scrollWidth > footerTagline.clientWidth + 1;
					footerTagline.textContent = isOverflowing ? 'Tarckit' : fullText;
				});
			};

			const closeAllDropdowns = () => {
				dropdowns.forEach((dropdown) => {
					dropdown.classList.remove('open');
					const trigger = dropdown.querySelector('.dropdown-trigger');
					if (trigger) trigger.setAttribute('aria-expanded', 'false');
				});
			};

			const syncMobileControlsCurrent = () => {
				if (!mobileControlsCurrent) return;
				const localeData = parsedConfig.locales[currentLocale] || parsedConfig.locales.hu;
				const activeTheme = root.getAttribute('data-theme') || 'light';
				const themeLabel = activeTheme === 'dark' ? localeData.themeDark : localeData.themeLight;
				mobileControlsCurrent.textContent = `${currentLocale.toUpperCase()} · ${themeLabel}`;
			};

			const applyLocale = (localeKey) => {
				const localeData = parsedConfig.locales[localeKey];
				if (!localeData) return;
				currentLocale = localeKey;

				document.documentElement.lang = localeKey;
				document.querySelectorAll('[data-i18n]').forEach((node) => {
					const key = node.getAttribute('data-i18n');
					if (!key || !localeData[key]) return;
					node.textContent = localeData[key];
				});

				document.querySelectorAll('[data-i18n-alt]').forEach((node) => {
					const key = node.getAttribute('data-i18n-alt');
					if (!key || !localeData[key]) return;
					node.setAttribute('alt', localeData[key]);
				});

				if (localeCurrent) {
					localeCurrent.textContent = localeKey.toUpperCase();
				}

				document.querySelectorAll('[data-locale-value]').forEach((item) => {
					item.classList.toggle('active', item.getAttribute('data-locale-value') === localeKey);
				});

				const activeTheme = root.getAttribute('data-theme') || 'light';
				if (themeCurrent) {
					themeCurrent.textContent = activeTheme === 'dark' ? localeData.themeDark : localeData.themeLight;
				}

				syncMobileControlsCurrent();

				const botondUrl = parsedConfig.company?.links?.botond?.[localeKey] || parsedConfig.company?.links?.botond?.en;
				const benceUrl = parsedConfig.company?.links?.bence?.[localeKey] || parsedConfig.company?.links?.bence?.en;

				if (botondLink && botondUrl) {
					botondLink.setAttribute('href', botondUrl);
					botondLink.textContent = botondUrl.replace('https://', '');
				}

				if (benceLink && benceUrl) {
					benceLink.setAttribute('href', benceUrl);
					benceLink.textContent = benceUrl.replace('https://', '');
				}

				syncFooterTaglineFit();
			};

			const applyTheme = (theme) => {
				root.setAttribute('data-theme', theme);
				document.querySelectorAll('[data-theme-value]').forEach((item) => {
					item.classList.toggle('active', item.getAttribute('data-theme-value') === theme);
				});

				if (themeCurrent) {
					const localeData = parsedConfig.locales[currentLocale] || parsedConfig.locales.hu;
					themeCurrent.textContent = theme === 'dark' ? localeData.themeDark : localeData.themeLight;
				}

				syncMobileControlsCurrent();

				localStorage.setItem('velox-theme', theme);
			};

			const openLightbox = (src, titleKey) => {
				if (!lightbox || !lightboxImage || !lightboxTitle) return;
				const localeData = parsedConfig.locales[currentLocale] || parsedConfig.locales.hu;
				lightboxImage.setAttribute('src', src);
				lightboxImage.setAttribute('alt', localeData[titleKey] || 'preview image');
				lightboxTitle.textContent = localeData[titleKey] || '';
				lightbox.hidden = false;
				document.body.style.overflow = 'hidden';
			};

			const closeLightbox = () => {
				if (!lightbox) return;
				lightbox.hidden = true;
				document.body.style.overflow = '';
			};

			const initialLocale = currentLocale;
			applyLocale(initialLocale);

			document.querySelectorAll('[data-locale-value]').forEach((item) => {
				item.addEventListener('click', () => {
					const localeValue = item.getAttribute('data-locale-value');
					if (!localeValue) return;
					applyLocale(localeValue);
					closeAllDropdowns();
				});
			});

			document.querySelectorAll('[data-theme-value]').forEach((item) => {
				item.addEventListener('click', () => {
					const themeValue = item.getAttribute('data-theme-value');
					if (!themeValue) return;
					applyTheme(themeValue);
					closeAllDropdowns();
				});
			});

			dropdowns.forEach((dropdown) => {
				const trigger = dropdown.querySelector('.dropdown-trigger');
				if (!trigger) return;

				trigger.addEventListener('click', (event) => {
					event.stopPropagation();
					const isOpen = dropdown.classList.contains('open');
					closeAllDropdowns();
					if (!isOpen) {
						dropdown.classList.add('open');
						trigger.setAttribute('aria-expanded', 'true');
					}
				});
			});

			document.addEventListener('click', (event) => {
				if (!event.target.closest('.custom-dropdown')) {
					closeAllDropdowns();
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeAllDropdowns();
					closeLightbox();
				}
			});

			document.querySelectorAll('[data-shot]').forEach((shot) => {
				const openFromShot = () => {
					const src = shot.getAttribute('data-shot-src');
					const titleKey = shot.getAttribute('data-shot-title-key');
					if (!src || !titleKey) return;
					openLightbox(src, titleKey);
				};

				shot.addEventListener('click', openFromShot);
				shot.addEventListener('keydown', (event) => {
					if (event.key === 'Enter' || event.key === ' ') {
						event.preventDefault();
						openFromShot();
					}
				});
			});

			document.querySelectorAll('[data-lightbox-close]').forEach((node) => {
				node.addEventListener('click', closeLightbox);
			});

			if (ctaNode) {
				const triggerRipple = () => window.dispatchEvent(new CustomEvent('hero-artifact:ripple'));
				ctaNode.addEventListener('mouseenter', triggerRipple);
				ctaNode.addEventListener('focus', triggerRipple);
				ctaNode.addEventListener('click', () => {
					window.location.href = 'mailto:contact@ballabotond.com,work@szilagyibence.com';
				});
			}

			const storedTheme = localStorage.getItem('velox-theme');
			const preferredDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			const initialTheme = storedTheme || (preferredDark ? 'dark' : 'light');
			applyTheme(initialTheme);

			if (floatingFooter || floatingHeader) {
				let lastY = window.scrollY;
				let ticking = false;
				const shouldAnimateBars = () => true;

				const updateBarsVisibility = () => {
					if (!shouldAnimateBars()) {
						floatingFooter?.classList.remove('is-hidden');
						floatingHeader?.classList.remove('is-hidden');
						lastY = window.scrollY;
						ticking = false;
						return;
					}

					const y = window.scrollY;
					const delta = y - lastY;

					if (y < 56 || delta < -2) {
						floatingFooter?.classList.remove('is-hidden');
						floatingHeader?.classList.remove('is-hidden');
					} else if (delta > 2) {
						floatingFooter?.classList.add('is-hidden');
						floatingHeader?.classList.add('is-hidden');
					}

					lastY = y;
					ticking = false;
				};

				window.addEventListener('scroll', () => {
					if (!ticking) {
						requestAnimationFrame(updateBarsVisibility);
						ticking = true;
					}
				}, { passive: true });

				window.addEventListener('resize', () => {
					updateBarsVisibility();
					syncFooterTaglineFit();
				}, { passive: true });
				updateBarsVisibility();
			}

			syncFooterTaglineFit();
		</script>

		<script>
			import Lenis from 'lenis';

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const enableLenis = window.innerWidth > 900;

			if (!reduceMotion && enableLenis) {
				const lenis = new Lenis({
					duration: 0.92,
					easing: (t) => 1 - Math.pow(1 - t, 3),
					smoothWheel: true,
					syncTouch: false,
					touchMultiplier: 1,
					wheelMultiplier: 0.92
				});

				const raf = (time: number) => {
					lenis.raf(time);
					requestAnimationFrame(raf);
				};

				requestAnimationFrame(raf);
			}
		</script>
	</body>
</html>
